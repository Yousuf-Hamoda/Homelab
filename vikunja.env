# -------------------------------------------------------
# Vikunja Environment Variables
# -------------------------------------------------------

# The public URL where Vikunja will be accessed
# Use your server's local IP for LAN-only, or your domain if exposed externally
# Example (local):  http://192.168.1.100:3456
# Example (domain): https://tasks.yourdomain.com
VIKUNJA_SERVICE_PUBLICURL=http://YOUR_SERVER_IP:3456

# JWT secret used to sign auth tokens — must be unique and kept private
# Generate with: openssl rand -hex 32
VIKUNJA_SERVICE_JWTSECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING